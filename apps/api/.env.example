# Required — app refuses to start without these
# Replace with your actual values — NEVER commit real keys to git

ANTHROPIC_API_KEY=your-anthropic-api-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
RESEND_API_KEY=your-resend-api-key-here
REDIS_URL=redis://localhost:6379

# Optional integrations (leave blank if not using)
FRESHBOOKS_CLIENT_ID=
FRESHBOOKS_CLIENT_SECRET=
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
WAVE_API_KEY=

# App config
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=100
MAX_EVIDENCE_FILE_SIZE_MB=25

# Development database (SQLite — no credentials needed)
DATABASE_URL=sqlite:///./dev.db
